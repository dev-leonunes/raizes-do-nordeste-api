generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  GERENTE
  ATENDENTE
  COZINHA
  CLIENTE
}

enum CanalPedido {
  APP
  TOTEM
  BALCAO
  PICKUP
  WEB
}

enum StatusPedido {
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_PREPARO
  PRONTO
  ENTREGUE
  CANCELADO
  PAGAMENTO_RECUSADO
}

enum StatusPagamento {
  PENDENTE
  APROVADO
  RECUSADO
}

enum MetodoPagamento {
  MOCK
}

enum TipoMovimentacaoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
}

enum AcaoAuditoria {
  USUARIO_LOGIN
  PEDIDO_CRIADO
  STATUS_PEDIDO_ATUALIZADO
  PEDIDO_CANCELADO
  PAGAMENTO_CRIADO
  PAGAMENTO_APROVADO
  PAGAMENTO_RECUSADO
  ESTOQUE_MOVIMENTADO
}

model Usuario {
  id        String        @id @default(uuid())
  nome      String
  email     String        @unique
  senhaHash String
  perfil    PerfilUsuario @default(CLIENTE)

  unidadeId String?
  unidade   Unidade? @relation(fields: [unidadeId], references: [id])

  pedidos              Pedido[]
  auditorias           Auditoria[]
  movimentacoesEstoque MovimentacaoEstoque[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}

model Unidade {
  id     String  @id @default(uuid())
  nome   String
  cidade String
  estado String
  ativa  Boolean @default(true)

  usuarios             Usuario[]
  estoques             Estoque[]
  movimentacoesEstoque MovimentacaoEstoque[]
  pedidos              Pedido[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("unidades")
}

model Produto {
  id        String  @id @default(uuid())
  nome      String
  descricao String?
  preco     Decimal @db.Decimal(10, 2)
  ativo     Boolean @default(true)

  estoques             Estoque[]
  movimentacoesEstoque MovimentacaoEstoque[]
  itensPedido          ItemPedido[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("produtos")
}

model Estoque {
  id String @id @default(uuid())

  unidadeId String
  produtoId String

  quantidade       Int @default(0)
  quantidadeMinima Int @default(0)

  unidade Unidade @relation(fields: [unidadeId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([unidadeId, produtoId])
  @@map("estoques")
}

model MovimentacaoEstoque {
  id String @id @default(uuid())

  unidadeId   String
  produtoId   String
  criadoPorId String?

  tipo       TipoMovimentacaoEstoque
  quantidade Int
  motivo     String?

  unidade  Unidade @relation(fields: [unidadeId], references: [id])
  produto  Produto @relation(fields: [produtoId], references: [id])
  criadoPor Usuario? @relation(fields: [criadoPorId], references: [id])

  criadoEm DateTime @default(now())

  @@map("movimentacoes_estoque")
}

model Pedido {
  id     String @id @default(uuid())
  codigo String @unique

  clienteId String
  unidadeId String

  canalPedido CanalPedido
  status      StatusPedido @default(AGUARDANDO_PAGAMENTO)

  valorTotal Decimal @db.Decimal(10, 2)

  cliente Usuario @relation(fields: [clienteId], references: [id])
  unidade Unidade @relation(fields: [unidadeId], references: [id])

  itens     ItemPedido[]
  pagamento Pagamento?

  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  canceladoEm  DateTime?

  @@map("pedidos")
}

model ItemPedido {
  id String @id @default(uuid())

  pedidoId  String
  produtoId String

  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  pedido  Pedido  @relation(fields: [pedidoId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  criadoEm DateTime @default(now())

  @@map("itens_pedido")
}

model Pagamento {
  id String @id @default(uuid())

  pedidoId String @unique

  metodo MetodoPagamento @default(MOCK)
  status StatusPagamento @default(PENDENTE)

  valor              Decimal @db.Decimal(10, 2)
  referenciaExterna String?
  payloadProvedor   Json?

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  pagoEm      DateTime?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("pagamentos")
}

model Auditoria {
  id String @id @default(uuid())

  usuarioId String?

  acao       AcaoAuditoria
  entidade   String
  entidadeId String?
  metadata   Json?

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  criadoEm DateTime @default(now())

  @@map("auditorias")
}
