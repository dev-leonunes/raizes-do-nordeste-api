{
  "info": {
    "name": "Raízes do Nordeste - API Back-end",
    "description": "Coleção local para evidenciar os fluxos principais e negativos do MVP Back-end. Execute pnpm db:setup antes de rodar a coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "unidadeId",
      "value": "00000000-0000-0000-0000-000000000001"
    },
    {
      "key": "produtoId",
      "value": "00000000-0000-0000-0000-000000000101"
    },
    {
      "key": "pedidoId",
      "value": ""
    },
    {
      "key": "pedidoRecusadoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Login válido como cliente",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cliente@raizes.local\",\n  \"senha\": \"Senha@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('returns access token', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('token', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Login válido como ADMIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@raizes.local\",\n  \"senha\": \"Senha@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('returns admin token', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('adminToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Acesso sem token retorna 401",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 401', () => pm.response.to.have.status(401));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Perfil sem permissão retorna 403",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["usuarios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 403', () => pm.response.to.have.status(403));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Campo obrigatório ausente retorna 422",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 422', () => pm.response.to.have.status(422));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Tipo ou formato inválido retorna 422",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": \"uma\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 422', () => pm.response.to.have.status(422));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Produto inexistente retorna 404",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    {\n      \"produtoId\": \"00000000-0000-0000-0000-000000009999\",\n      \"quantidade\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 404', () => pm.response.to.have.status(404));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Estoque insuficiente retorna 409",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"WEB\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": 9999\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('returns 409', () => pm.response.to.have.status(409));"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "09 - Pedido válido criado com sucesso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('starts waiting for payment', () => pm.expect(json.status).to.eql('AGUARDANDO_PAGAMENTO'));",
              "pm.collectionVariables.set('pedidoId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10 - Pagamento mock aprovado atualiza status",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"aprovado\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos/{{pedidoId}}/pagamentos/mock",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos", "{{pedidoId}}", "pagamentos", "mock"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('updates order status to paid', () => pm.expect(json.status).to.eql('PAGO'));",
              "pm.test('stores approved payment', () => pm.expect(json.pagamento.status).to.eql('APROVADO'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11 - Criar pedido para pagamento recusado",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"TOTEM\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('pedidoRecusadoId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12 - Pagamento mock recusado retorna status coerente",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"aprovado\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pedidos/{{pedidoRecusadoId}}/pagamentos/mock",
          "host": ["{{baseUrl}}"],
          "path": ["pedidos", "{{pedidoRecusadoId}}", "pagamentos", "mock"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('updates order status to refused payment', () => pm.expect(json.status).to.eql('PAGAMENTO_RECUSADO'));",
              "pm.test('stores refused payment', () => pm.expect(json.pagamento.status).to.eql('RECUSADO'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "13 - Consulta de auditorias com ADMIN",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auditorias?page=1&limit=10&entidade=Pedido",
          "host": ["{{baseUrl}}"],
          "path": ["auditorias"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "entidade",
              "value": "Pedido"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('returns paginated audit data', () => {",
              "  pm.expect(json.data).to.be.an('array');",
              "  pm.expect(json.meta).to.have.property('page', 1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
