{
  "info": {
    "name": "Raízes do Nordeste - API Back-end",
    "description": "Coleção local para evidenciar os fluxos principais e negativos do MVP Back-end. Execute pnpm db:setup antes de rodar a coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "gerenteToken",
      "value": ""
    },
    {
      "key": "usuarioRegistradoToken",
      "value": ""
    },
    {
      "key": "unidadeId",
      "value": "11111111-1111-4111-8111-111111111111"
    },
    {
      "key": "outraUnidadeId",
      "value": "33333333-3333-4333-8333-333333333333"
    },
    {
      "key": "produtoId",
      "value": "22222222-2222-4222-8222-222222222222"
    },
    {
      "key": "pedidoId",
      "value": ""
    },
    {
      "key": "pedidoRecusadoId",
      "value": ""
    },
    {
      "key": "pedidoCancelamentoId",
      "value": ""
    },
    {
      "key": "funcionarioId",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const defaults = {",
          "  baseUrl: 'http://localhost:3000',",
          "  unidadeId: '11111111-1111-4111-8111-111111111111',",
          "  outraUnidadeId: '33333333-3333-4333-8333-333333333333',",
          "  produtoId: '22222222-2222-4222-8222-222222222222',",
          "};",
          "",
          "Object.entries(defaults).forEach(([key, value]) => {",
          "  if (!pm.collectionVariables.get(key)) {",
          "    pm.collectionVariables.set(key, value);",
          "  }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Obrigatorios - evidencias principais",
      "item": [
        {
          "name": "01 - Login válido como cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@raizes.local\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('returns access token', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('token', json.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
