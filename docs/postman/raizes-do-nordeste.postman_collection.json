        {
          "name": "03 - Registrar novo usuário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Postman\",\n  \"email\": \"cliente.postman.{{$timestamp}}@raizes.local\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/registrar",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "registrar"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('returns registered user token', () => pm.expect(json.accessToken).to.be.a('string').and.not.empty);",
                  "pm.test('public registration always creates client without unit', () => {",
                  "  pm.expect(json.usuario.perfil).to.eql('CLIENTE');",
                  "  pm.expect(json.usuario.unidadeId).to.be.null;",
                  "});",
                  "pm.test('does not expose password hash', () => pm.expect(json.usuario).not.to.have.property('senhaHash'));",
                  "pm.collectionVariables.set('usuarioRegistradoToken', json.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
